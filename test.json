{
  "info": {
    "name": "Rikkei Bank API - Full Features",
    "description": "Collection test tất cả tính năng: Auth (JWT + Refresh + Revoke), Register, eKYC, Account, Transfer, Statement, etc.",
    "_postman_id": "rikkei-bank-full-test"
  },
  "item": [
    {
      "name": "1. Auth & Security",
      "item": [
        {
          "name": "Register (Đăng ký)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"customer01\",\n  \"password\": \"Password123!\",\n  \"email\": \"customer01@example.com\",\n  \"fullName\": \"Nguyễn Văn A\",\n  \"phone\": \"0123456789\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/api/auth/register"
          }
        },
        {
          "name": "Login (Cấp JWT)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"customer01\",\n  \"password\": \"Password123!\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/api/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.environment.set('accessToken', json.data.accessToken);",
                  "    pm.environment.set('refreshToken', json.data.refreshToken);",
                  "    console.log('✅ Tokens saved');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/api/auth/refresh"
          }
        },
        {
          "name": "Logout (Revoke Token)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{base_url}}/api/auth/logout"
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"customer01\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/api/auth/forgot-password"
          }
        }
      ]
    },
    {
      "name": "2. Customer Features",
      "item": [
        {
          "name": "Upload eKYC",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "idNumber", "value": "123456789", "type": "text" },
                { "key": "fullName", "value": "Nguyễn Văn A", "type": "text" },
                { "key": "dob", "value": "2000-01-01", "type": "text" },
                { "key": "sex", "value": "MALE", "type": "text" },
                { "key": "address", "value": "Hà Nội", "type": "text" },
                { "key": "file", "type": "file", "src": [] }
              ]
            },
            "url": "{{base_url}}/api/v1/customer/kyc/upload"
          }
        },
        {
          "name": "Get Balance",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{base_url}}/api/v1/customer/accounts/balance"
          }
        },
        {
          "name": "Transfer Money",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"toAccountNumber\": \"ACCOUNT_002\",\n  \"amount\": 1000000,\n  \"pin\": \"123456\",\n  \"description\": \"Chuyển tiền test\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/api/v1/customer/accounts/transfer"
          }
        },
        {
          "name": "Transaction Statement (with pagination)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/customer/accounts/statement?page=0&size=10",
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Change PIN",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"oldPin\": \"123456\",\n  \"newPin\": \"654321\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/api/v1/customer/accounts/change-pin"
          }
        }
      ]
    },
    {
      "name": "3. Staff / Admin",
      "item": [
        {
          "name": "Approve eKYC (STAFF)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/staff/kyc/approve/{{kycId}}?status=CONFIRM",
              "query": [{ "key": "status", "value": "CONFIRM" }]
            }
          }
        },
        {
          "name": "Get All Users (Pagination)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{base_url}}/api/v1/users?page=0&size=10"
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" }
  ]
}